<div data-controller="terminal">

  <div id="login-screen" class="full-screen" data-terminal-target="loginScreen">
    <div class="box">
      <h1>Accesso al Portale</h1>

      <label>
        Username
        <input type="text" data-terminal-target="loginUsername" data-action="keydown.enter->terminal#attemptLogin" />
      </label>

      <label>
        Password
        <input type="password" data-terminal-target="loginPassword" data-action="keydown.enter->terminal#attemptLogin" />
      </label>

      <div style="text-align: right; margin-bottom: 20px;">
        <a href="#" class="forgot-password-link" data-action="click->terminal#forgotPassword">Password dimenticata?</a>
      </div>

      <button type="button" data-action="click->terminal#attemptLogin">Continua</button>

      <p style="margin-top: 20px; font-size: 0.8em; color: #0aff0a;">Nuovə utente?</p>
      <button type="button" class="secondary" data-action="click->terminal#showRegistrationScreen">Registrati</button>

      <div class="error" data-terminal-target="loginError"></div>
    </div>
  </div>

  <div id="code-screen" class="full-screen" data-terminal-target="codeScreen" style="display:none;">
    <div class="box">
      <h1>Codice di Sicurezza</h1>
      <label>
        Inserire parola d'ordine
        <input type="text"
               style="text-transform: uppercase;"
               data-terminal-target="codeInput"
               data-action="keydown.enter->terminal#verifyCode" />
      </label>
      <button type="button" data-action="click->terminal#verifyCode">Verifica Codice</button>
      <button type="button" class="link" data-action="click->terminal#backToLogin">Indietro</button>
      <div class="error" data-terminal-target="codeError"></div>
    </div>
  </div>

  <div id="registration-screen" class="full-screen" data-terminal-target="registrationScreen" style="display:none;">
    <div class="box">
      <h1>Registrati</h1>

      <label>Username <input type="text" data-terminal-target="regUsername" /></label>
      <label>Email <input type="email" data-terminal-target="regEmail" /></label>
      <label>Password <input type="password" data-terminal-target="regPassword" /></label>
      <label>Conferma Password <input type="password" data-terminal-target="regPasswordConfirm" /></label>

      <div class="checkbox-group" style="text-align: left; margin-top: 15px;">
        <label>
          <input type="checkbox" data-terminal-target="regPrivacy" />
          <span>Accetto l' <a href="#" style="color: #0aff0a;">informativa privacy</a> (Obbligatorio)</span>
        </label>

        <label>
          <input type="checkbox" data-terminal-target="regPromo" />
          <span>Consenso comunicazioni operative</span>
        </label>
      </div>

      <button type="button" style="margin-top: 20px;" data-action="click->terminal#submitRegistration">Registrati</button>
      <button type="button" class="link" data-action="click->terminal#backToLogin">Annulla</button>

      <div class="error" data-terminal-target="regError" style="color: red; margin-top: 10px;"></div>
    </div>
  </div>

  <div id="terminal" data-terminal-target="terminal" style="display:none;">
    <div id="screen" data-terminal-target="screen"></div>

    <div id="inputbar">
      <span class="prompt-symbol">/</span>

      <input type="text"
         id="prompt"
         data-terminal-target="prompt"
         data-action="keydown.enter->terminal#onPromptEnter"
         autocomplete="off"
         autocorrect="off"
         autocapitalize="none"
         spellcheck="false"
         data-1p-ignore
         enterkeyhint="send"
         placeholder="Digita un comando...">

      <button type="button" id="prompt-send-btn" data-action="click->terminal#onPromptEnter">
        ➤
      </button>
    </div>
  </div>

</div>
