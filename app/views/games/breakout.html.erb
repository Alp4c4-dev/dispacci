<div style="max-width: 1100px; margin: 16px auto; padding: 0 12px; font-family: monospace;">
  <h1 style="margin: 8px 0;">Aurelius // "DATA HEIST"</h1>

  <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom: 8px;">
    <div>Dati sottratti: <span id="ui-mb">0</span> MB</div>
    <div>Vite: <span id="ui-lives">3</span></div>
    <div id="ui-status"></div>
  </div>

  <canvas id="game" width="900" height="540"
    style="width: 100%; max-width: 1000px; aspect-ratio: 5/3; background:#0b1220; border-radius: 12px; border: 1px solid rgba(255,255,255,0.15); touch-action: none;">
  </canvas>
</div>

<script>
(() => {
  const canvas = document.getElementById("game");
  const ctx = canvas.getContext("2d");
  const uiMb = document.getElementById("ui-mb");
  const uiLives = document.getElementById("ui-lives");
  const uiStatus = document.getElementById("ui-status");

  const W = () => canvas.width;
  const H = () => canvas.height;

  // ----- CSRF helper (Rails) -----
  function csrfToken() {
    return document.querySelector("meta[name='csrf-token']")?.content || "";
  }

  async function saveScore(score, startedAtIso) {
    try {
      const res = await fetch("/game_sessions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "X-CSRF-Token": csrfToken()
        },
        body: JSON.stringify({ game_key: "breakout", score, started_at: startedAtIso })
      });
      const data = await res.json().catch(() => ({}));
      return (res.ok && data.ok) ? { ok: true } : { ok: false, error: data.error || "Errore" };
    } catch (e) {
      return { ok: false, error: "Network error" };
    }
  }

  function formatThousands(n) {
    return Number(n).toLocaleString("it-IT");
  }

  function startCountdownAndReturn(seconds) {
    let left = seconds;
    const tick = () => {
      uiStatus.textContent = `Ritorno al Portale tra ${left}s...`;
      left -= 1;
      if (left < 0) {
        history.back(); // torna al terminale
        return;
      }
      setTimeout(tick, 1000);
    };
    tick();
  }

  // ----- Game state -----
  let startedAtIso = null;
  let running = true;
  let finished = false;

  const state = {
    lives: 3,
    blocksDestroyed: 0,
    paddle: { w: 140, h: 14, x: 0, y: 0 },
    ball: { x: 0, y: 0, vx: 260, vy: -260, r: 8 },
    bricks: [],
    brick: { rows: 6, cols: 10, w: 0, h: 20, pad: 10, top: 70, left: 30 }
  };

  function resetBricks() {
    const bw = (W() - state.brick.left * 2 - state.brick.pad * (state.brick.cols - 1)) / state.brick.cols;
    state.brick.w = bw;

    state.bricks = [];
    for (let r = 0; r < state.brick.rows; r++) {
      for (let c = 0; c < state.brick.cols; c++) {
        state.bricks.push({
          x: state.brick.left + c * (bw + state.brick.pad),
          y: state.brick.top + r * (state.brick.h + state.brick.pad),
          w: bw,
          h: state.brick.h,
          alive: true
        });
      }
    }
  }

  function resetBallAndPaddle() {
    state.paddle.x = (W() - state.paddle.w) / 2;
    state.paddle.y = H() - 50;

    state.ball.x = W() / 2;
    state.ball.y = state.paddle.y - state.ball.r - 2;

    state.ball.vx = 240;
    state.ball.vy = -260;
  }

  function init() {
    state.lives = 3;
    state.blocksDestroyed = 0;
    uiLives.textContent = "3";
    uiMb.textContent = "0";
    uiStatus.textContent = "";
    running = true;
    finished = false;
    startedAtIso = new Date().toISOString();

    resetBricks();
    resetBallAndPaddle();
  }

  // ----- Input: mouse/touch -> paddle -----
  function setPaddleFromClientX(clientX) {
    const rect = canvas.getBoundingClientRect();
    const x = (clientX - rect.left) * (canvas.width / rect.width);
    state.paddle.x = Math.max(0, Math.min(W() - state.paddle.w, x - state.paddle.w / 2));
  }

  canvas.addEventListener("mousemove", (e) => setPaddleFromClientX(e.clientX));
  canvas.addEventListener("touchstart", (e) => {
    if (e.touches?.[0]) setPaddleFromClientX(e.touches[0].clientX);
  }, { passive: true });
  canvas.addEventListener("touchmove", (e) => {
    if (e.touches?.[0]) setPaddleFromClientX(e.touches[0].clientX);
  }, { passive: true });

  // ----- Collision helpers -----
  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }

  function circleRectCollide(cx, cy, r, rx, ry, rw, rh) {
    const closestX = clamp(cx, rx, rx + rw);
    const closestY = clamp(cy, ry, ry + rh);
    const dx = cx - closestX;
    const dy = cy - closestY;
    return (dx * dx + dy * dy) <= (r * r);
  }

  function mbStolen() {
    return state.blocksDestroyed * 10; // ✅ 10 MB per blocco
  }

  async function finishAndReturn(isWin) {
    if (finished) return;
    finished = true;
    running = false;

    const mb = mbStolen();
    uiMb.textContent = String(mb);
    uiStatus.textContent = `Grazie! Hai distrutto ${formatThousands(mb)} MB di dati.`;

    // salva “score” come MB (o puoi salvare blocksDestroyed)
    const res = await saveScore(mb, startedAtIso);
    if (!res.ok) uiStatus.textContent += " (impossibile salvare)";

    startCountdownAndReturn(6);
  }

  // ----- Update loop -----
  let last = performance.now();
  function step(now) {
    const dt = Math.min(0.02, (now - last) / 1000);
    last = now;

    if (running && !finished) update(dt);
    draw();
    requestAnimationFrame(step);
  }

  function update(dt) {
    // move ball
    state.ball.x += state.ball.vx * dt;
    state.ball.y += state.ball.vy * dt;

    // walls
    if (state.ball.x - state.ball.r <= 0) { state.ball.x = state.ball.r; state.ball.vx *= -1; }
    if (state.ball.x + state.ball.r >= W()) { state.ball.x = W() - state.ball.r; state.ball.vx *= -1; }
    if (state.ball.y - state.ball.r <= 0) { state.ball.y = state.ball.r; state.ball.vy *= -1; }

    // bottom -> lose life
    if (state.ball.y - state.ball.r > H()) {
      state.lives -= 1;
      uiLives.textContent = String(state.lives);

      if (state.lives <= 0) {
        finishAndReturn(false);
        return;
      }

      resetBallAndPaddle();
      return;
    }

    // paddle collision
    const p = state.paddle;
    if (circleRectCollide(state.ball.x, state.ball.y, state.ball.r, p.x, p.y, p.w, p.h) && state.ball.vy > 0) {
      const hit = (state.ball.x - (p.x + p.w / 2)) / (p.w / 2); // -1..1
      const speed = Math.sqrt(state.ball.vx * state.ball.vx + state.ball.vy * state.ball.vy);
      const maxAngle = Math.PI * 0.35;
      const angle = hit * maxAngle;

      state.ball.vx = speed * Math.sin(angle);
      state.ball.vy = -Math.abs(speed * Math.cos(angle));
      state.ball.y = p.y - state.ball.r - 1;
    }

    // bricks
    let aliveCount = 0;
    for (const b of state.bricks) {
      if (!b.alive) continue;
      aliveCount++;

      if (circleRectCollide(state.ball.x, state.ball.y, state.ball.r, b.x, b.y, b.w, b.h)) {
        b.alive = false;
        state.blocksDestroyed += 1;

        const mb = mbStolen();
        uiMb.textContent = String(mb);

        // bounce
        const bx = b.x + b.w / 2;
        const by = b.y + b.h / 2;
        const dx = state.ball.x - bx;
        const dy = state.ball.y - by;
        if (Math.abs(dx) > Math.abs(dy)) state.ball.vx *= -1;
        else state.ball.vy *= -1;

        break;
      }
    }

    if (aliveCount === 0) {
      finishAndReturn(true);
    }
  }

  // ----- Draw -----
  function draw() {
    ctx.clearRect(0, 0, W(), H());

    // grid
    ctx.globalAlpha = 0.12;
    ctx.beginPath();
    for (let x = 0; x <= W(); x += 30) { ctx.moveTo(x, 0); ctx.lineTo(x, H()); }
    for (let y = 0; y <= H(); y += 30) { ctx.moveTo(0, y); ctx.lineTo(W(), y); }
    ctx.strokeStyle = "#ffffff";
    ctx.stroke();
    ctx.globalAlpha = 1;

    // bricks
    for (const b of state.bricks) {
      if (!b.alive) continue;
      ctx.fillStyle = "rgba(255,255,255,0.22)";
      ctx.fillRect(b.x, b.y, b.w, b.h);
    }

    // paddle
    ctx.fillStyle = "rgba(255,255,255,0.8)";
    ctx.fillRect(state.paddle.x, state.paddle.y, state.paddle.w, state.paddle.h);

    // ball
    ctx.beginPath();
    ctx.arc(state.ball.x, state.ball.y, state.ball.r, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(255,255,255,0.95)";
    ctx.fill();

    // subtle hint only at start
    if (!finished && startedAtIso && state.blocksDestroyed === 0 && state.lives === 3) {
      ctx.fillStyle = "rgba(255,255,255,0.75)";
      ctx.font = "16px monospace";
      ctx.fillText("Muovi la barra con mouse/touch.", 30, 40);
    }
  }

  init();
  requestAnimationFrame(step);
})();
</script>